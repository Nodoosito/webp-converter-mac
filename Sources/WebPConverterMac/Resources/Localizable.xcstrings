    "settings.quality.help": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajuste le niveau de compression. Une valeur élevée préserve les détails originaux, une valeur basse maximise l'espace disque économisé."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjusts the compression level. A high value preserves more original detail, while a low value maximizes disk-space savings."
          }
        }
      }
    },
    "settings.metadata.label": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer les métadonnées"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove metadata"
          }
        }
      }
    },
    "settings.metadata.help": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprime les données techniques (EXIF, GPS, réglages boîtier) pour alléger le fichier et protéger la confidentialité de vos prises de vue."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Removes technical data (EXIF, GPS, camera settings) to reduce file size and protect your photo privacy."
          }
        }
      }
    },
    "settings.suffix.label": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suffixe"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Suffix"
          }
        }
      }
    },
    "settings.suffix.help": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoute un texte au nom du fichier pour identifier rapidement ses variantes (ex: dimensions ou usage)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adds text to the filename so you can quickly identify variants such as dimensions or usage."
          }
        }
      }
    },
